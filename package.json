{
  "name": "rest-test",
  "displayName": "REST TEST",
  "description": "Professional REST & GraphQL API testing extension for VS Code with sleek dark-themed UI, fast performance, and comprehensive request management",
  "version": "4.1.3",
  "publisher": "GopherAmol",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gopheramol/rest-test"
  },
  "engines": {
    "vscode": "^1.67.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "resources/icon.png",
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "restApiTester",
          "title": "REST TEST",
          "icon": "resources/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "restApiTester": [
        {
          "id": "restApiTesterView",
          "name": "API Requests"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "restApiTest.sendRequest",
          "when": "view == restApiTesterView",
          "group": "navigation@1"
        },
        {
          "command": "restApiTest.newCollection",
          "when": "view == restApiTesterView",
          "group": "navigation@2"
        },
        {
          "command": "restApiTest.importCollection",
          "when": "view == restApiTesterView",
          "group": "navigation@3"
        },
        {
          "command": "restApiTest.refreshView",
          "when": "view == restApiTesterView",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "restApiTest.renameCollection",
          "when": "view == restApiTesterView && viewItem == collection",
          "group": "1_modify@1"
        },
        {
          "command": "restApiTest.exportCollection",
          "when": "view == restApiTesterView && viewItem == collection",
          "group": "1_modify@2"
        },
        {
          "command": "restApiTest.deleteCollection",
          "when": "view == restApiTesterView && viewItem == collection",
          "group": "2_danger@1"
        },
        {
          "command": "restApiTest.moveRequest",
          "when": "view == restApiTesterView && viewItem == saved-request",
          "group": "1_modify@1"
        },
        {
          "command": "restApiTest.deleteRequest",
          "when": "view == restApiTesterView && viewItem == saved-request",
          "group": "2_danger@1"
        }
      ]
    },
    "commands": [
      {
        "command": "restApiTest.sendRequest",
        "title": "Send New Request",
        "icon": "$(add)"
      },
      {
        "command": "restApiTest.refreshView",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "restApiTest.newCollection",
        "title": "New Collection",
        "icon": "$(new-folder)"
      },
      {
        "command": "restApiTest.importCollection",
        "title": "Import Postman Collection",
        "icon": "$(cloud-download)"
      },
      {
        "command": "restApiTest.exportCollection",
        "title": "Export as Postman Collection",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "restApiTest.renameCollection",
        "title": "Rename Collection",
        "icon": "$(edit)"
      },
      {
        "command": "restApiTest.deleteCollection",
        "title": "Delete Collection",
        "icon": "$(trash)"
      },
      {
        "command": "restApiTest.moveRequest",
        "title": "Move to Collection…",
        "icon": "$(arrow-right)"
      },
      {
        "command": "restApiTest.deleteRequest",
        "title": "Delete Request",
        "icon": "$(trash)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.9",
    "@types/node": "20.x",
    "@types/vscode": "^1.67.0",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.7.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.13.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "axios": "^1.7.7"
  }
}